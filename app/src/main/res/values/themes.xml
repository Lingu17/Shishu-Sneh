<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ShishuSneh" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accentColor</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/accentLightColor</item>
        <item name="colorOnPrimaryContainer">@color/accentDarkColor</item>
        
        <item name="colorSecondary">@color/primaryColor</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="android:windowBackground">@color/backgroundColor</item>
        <item name="android:statusBarColor">@color/backgroundColor</item>
        <item name="android:windowLightStatusBar">true</item>

        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Typography Hierarchy -->
    <style name="TextHeadline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textColor">@color/primaryTextColor</item>
        <item name="android:textSize">26sp</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textColor">@color/primaryTextColor</item>
        <item name="android:textSize">20sp</item>
    </style>

    <style name="TextSection" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/primaryTextColor</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="TextSubtitle" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/secondaryTextColor</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextBody" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/secondaryTextColor</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextBodyBold" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textColor">@color/primaryTextColor</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- Premium Components -->
    <style name="PremiumCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="App.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">#E0F2F1</item>
        <item name="android:width">48dp</item>
        <item name="android:height">48dp</item>
    </style>
</resources>
